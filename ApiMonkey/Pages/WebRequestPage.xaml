<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ApiMonkey.Pages.WebRequestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ApiMonkey"
    xmlns:models="using:ApiMonkey.Models"
    xmlns:pages="using:ApiMonkey.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="36,24,36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Saved Request Info -->
        <Grid Grid.ColumnSpan="2"
              Padding="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBox Text="{x:Bind ViewModel.Request.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="24"
                     FontWeight="Black"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="-10,0,0,0"
                     MinWidth="400"/>
        </Grid>

        <!-- Request Data -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="16"
                       Padding="5"
                       TextAlignment="Center">
                Request
            </TextBlock>

            <Grid Grid.Row="1"
                  VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="MethodComboBox" 
                          ItemsSource="{x:Bind ViewModel.Methods}"
                          SelectedItem="{x:Bind ViewModel.Request.Method, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Grid.Column="0" 
                          Margin="5" 
                          Width="100" />

                <TextBox x:Name="UrlTextBox" 
                         Grid.Column="1" 
                         Margin="5" 
                         PlaceholderText="https://api.example.com/endpoint"
                         Text="{x:Bind ViewModel.Request.Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <Button x:Name="SendButton" 
                        Grid.Column="2" 
                        Margin="5" 
                        IsEnabled="{x:Bind ViewModel.IsSending, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                        Command="{x:Bind ViewModel.SendCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ProgressRing IsActive="{x:Bind ViewModel.IsSending, Mode=OneWay}" 
                                      Width="16" 
                                      Height="16" 
                                      Visibility="{x:Bind ViewModel.IsSending, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Text="{x:Bind ViewModel.IsSending, Mode=OneWay, Converter={StaticResource SendButtonTextConverter}}" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Request Data -->
            <TabView x:Name="RequestTabView"
                     IsAddTabButtonVisible="False"
                     VerticalAlignment="Stretch"
                     SelectionChanged="RequestTabView_SelectionChanged"
                     Grid.Row="3">
                <TabViewItem Header="Headers"
                             x:Name="RequestHeadersTab"
                             IsClosable="False">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="List" />
                    </TabViewItem.IconSource>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ScrollViewer>
                            <StackPanel Orientation="Vertical">
                                <ListView ItemsSource="{x:Bind ViewModel.RequestHeaders}"
                                          SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="pages:HeaderEntry">
                                            <Grid Padding="5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBox Text="{x:Bind Header.Name, Mode=TwoWay}"
                                                     FontWeight="Bold"
                                                     VerticalAlignment="Center" />

                                                <TextBox Text="{x:Bind Header.Value, Mode=TwoWay}" 
                                                         Grid.Column="1" 
                                                         Margin="5,0,0,0"  />

                                                <!-- TODO: This doesn't work, use a wrapper around Header, like we did for RequestRootEntry -->
                                                <Button Grid.Column="2"
                                                        Margin="5,0,0,0"
                                                        Command="{x:Bind Owner.RemoveRequestHeaderCommand}"
                                                        CommandParameter="{x:Bind}">
                                                    <FontIcon Glyph="&#xE894;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </ScrollViewer>

                        <Button Grid.Row="1"
                                Margin="5"
                                Content="Add Header"
                                Command="{x:Bind ViewModel.AddRequestHeaderCommand}" />
                    </Grid>
                </TabViewItem>
                <TabViewItem Header="Body"
                             x:Name="RequestBodyTab"
                             IsClosable="False">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="Document" />
                    </TabViewItem.IconSource>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBox x:Name="RequestBodyTextBox" 
                                 Grid.Column="0" 
                                 Margin="5" 
                                 AcceptsReturn="True" 
                                 TextWrapping="Wrap" 
                                 PlaceholderText="Request Body (for POST, PUT, PATCH)"
                             Text="{x:Bind ViewModel.Request.Body, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </TabViewItem>
            </TabView>
        </Grid>

        <!-- Response Data -->
        <Grid Grid.Column="1"
              Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" 
                               MinHeight="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="16"
                       Padding="5"
                       TextAlignment="Center">
                Response
            </TextBlock>

            <!-- Error Message Display -->
            <InfoBar Grid.Row="1"
                     Margin="5,0,5,5"
                     IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource StringToBoolConverter}}"
                     Severity="Error"
                     Title="Error"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     IsClosable="True" />

            <!-- Response Data -->
            <TabView IsAddTabButtonVisible="False"
                     x:Name="ResponseTabView"
                     VerticalAlignment="Stretch"
                     SelectionChanged="ResponseTabView_SelectionChanged"
                     Grid.Row="2">
                <TabViewItem IsClosable="False"
                             x:Name="ResponseHeadersTab">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="List" />
                    </TabViewItem.IconSource>

                    <TabViewItem.Header>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="5">
                            <TextBlock>Headers</TextBlock>
                            <InfoBadge Value="{x:Bind ViewModel.ResponseHeaderCount, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.ResponseLoaded, Mode=OneWay,
                                                    Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </TabViewItem.Header>
                    <ListView ItemsSource="{x:Bind ViewModel.ResponseHeaders}"
                              SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Header">
                                <Grid Padding="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Text="{x:Bind Name}" 
                                             FontWeight="Bold" 
                                             VerticalAlignment="Center"
                                             IsReadOnly="True"/>

                                    <TextBox Text="{x:Bind Value}" 
                                             Grid.Column="1" 
                                             Margin="5,0,0,0" 
                                             IsReadOnly="True" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabViewItem>
                <TabViewItem IsClosable="False"
                             x:Name="ResponseBodyTab">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="Document" />
                    </TabViewItem.IconSource>

                    <TabViewItem.Header>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="5">
                            <TextBlock>Body</TextBlock>
                            <InfoBadge Value="{x:Bind ViewModel.ResponseBodyLength, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.ResponseLoaded, Mode=OneWay,
                                                    Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </TabViewItem.Header>
                    <TextBox x:Name="ResponseTextBox" 
                             Grid.Column="1" 
                             Margin="5" 
                             AcceptsReturn="True" 
                             TextWrapping="Wrap" 
                             IsReadOnly="True" 
                             PlaceholderText="Response will appear here" 
                             Text="{x:Bind ViewModel.ResponseBody, Mode=OneWay}" />
                </TabViewItem>
            </TabView>
        </Grid>
    </Grid>
</Page>
