<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ApiMonkey.Pages.WebRequestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ApiMonkey"
    xmlns:models="using:ApiMonkey.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <!-- Saved Request Info -->
        <Grid Grid.ColumnSpan="2"
              Padding="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBox Header="Request Name"
                     Text="{x:Bind CurrentRequest.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="400"/>
        </Grid>

        <!-- Request Data -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="16"
                       Padding="5"
                       TextAlignment="Center">
                Request
            </TextBlock>

            <Grid Grid.Row="1"
                  VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="MethodComboBox" 
                          Grid.Column="0" 
                          Margin="5" 
                          Width="100">
                    <ComboBoxItem Content="GET" 
                                  IsSelected="True" />
                    <ComboBoxItem Content="POST" />
                    <ComboBoxItem Content="PUT" />
                    <ComboBoxItem Content="DELETE" />
                    <ComboBoxItem Content="PATCH" />
                </ComboBox>

                <TextBox x:Name="UrlTextBox" 
                         Grid.Column="1" 
                         Margin="5" 
                         PlaceholderText="https://api.example.com/endpoint"
                         Text="https://echo.free.beeceptor.com"/>

                <Button x:Name="SendButton" 
                        Grid.Column="2" 
                        Margin="5" 
                        Content="Send" 
                        Click="SendButton_Click" />
            </Grid>

            <!-- Request Data -->
            <TabView IsAddTabButtonVisible="False"
                     VerticalAlignment="Stretch"
                     Grid.Row="2">
                <TabViewItem Header="Headers"
                             IsClosable="False">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="List" />
                    </TabViewItem.IconSource>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ScrollViewer>
                            <StackPanel Orientation="Vertical">
                                <ListView x:Name="RequestHeadersListView">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:Header">
                                            <Grid Padding="5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBox Text="{x:Bind Name, Mode=TwoWay}" 
                                                         FontWeight="Bold" 
                                                         VerticalAlignment="Center"/>

                                                <TextBox Text="{x:Bind Value, Mode=TwoWay}" 
                                                         Grid.Column="1" 
                                                         Margin="5,0,0,0"  />

                                                <Button Grid.Column="2" 
                                                        Margin="5,0,0,0" 
                                                        Click="RemoveRequestHeaderButton_Click">
                                                    <FontIcon Glyph="&#xE894;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </ScrollViewer>

                        <Button x:Name="AddRequestHeaderButton" 
                                Grid.Row="1"
                                Margin="5"
                                Content="Add Header" 
                                Click="AddRequestHeaderButton_Click" />
                    </Grid>
                </TabViewItem>
                <TabViewItem Header="Body"
                             IsSelected="True"
                             IsClosable="False">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="Document" />
                    </TabViewItem.IconSource>
                    
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBox x:Name="RequestBodyTextBox" 
                                 Grid.Column="0" 
                                 Margin="5" 
                                 AcceptsReturn="True" 
                                 TextWrapping="Wrap" 
                                 PlaceholderText="Request Body (for POST, PUT, PATCH)" />
                    </Grid>
                </TabViewItem>
            </TabView>
        </Grid>

        <!-- Response Data -->
        <Grid Grid.Column="1"
              Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="16"
                       Padding="5"
                       TextAlignment="Center">
                Response
            </TextBlock>

            <!-- Response Data -->
            <TabView IsAddTabButtonVisible="False"
                     VerticalAlignment="Stretch"
                     Grid.Row="2">
                <TabViewItem IsClosable="False">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="List" />
                    </TabViewItem.IconSource>
                    
                    <TabViewItem.Header>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="5">
                            <TextBlock>Headers</TextBlock>
                            <InfoBadge x:Name="ResponseHeadersInfoBadge"
                                       Value="1" 
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </TabViewItem.Header>
                    <ListView x:Name="ResponseHeadersListView">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Header">
                                <Grid Padding="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Text="{x:Bind Name}" 
                                             FontWeight="Bold" 
                                             VerticalAlignment="Center"
                                             IsReadOnly="True"/>

                                    <TextBox Text="{x:Bind Value}" 
                                             Grid.Column="1" 
                                             Margin="5,0,0,0" 
                                             IsReadOnly="True" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabViewItem>
                <TabViewItem IsClosable="False">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="Document" />
                    </TabViewItem.IconSource>

                    <TabViewItem.Header>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="5">
                            <TextBlock>Body</TextBlock>
                            <InfoBadge x:Name="ResponseBodyInfoBadge"
                                       Value="1" 
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </TabViewItem.Header>
                    <TextBox x:Name="ResponseTextBox" 
                             Grid.Column="1" 
                             Margin="5" 
                             AcceptsReturn="True" 
                             TextWrapping="Wrap" 
                             IsReadOnly="True" 
                             PlaceholderText="Response will appear here" />
                </TabViewItem>
            </TabView>
        </Grid>
    </Grid>
</Page>
