<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ApiMonkey.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ApiMonkey"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ApiMonkey">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid"
          Loaded="RootGrid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="TitleBar"
                  Title="ApiMonkey"
                  IsBackButtonVisible="False"
                  PaneToggleRequested="TitleBar_PaneToggleRequested"
                  IsPaneToggleButtonVisible="True">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/Icon.ico" />
            </TitleBar.IconSource>

            <TitleBar.Content>
                <!--
                    TODO: https://github.com/microsoft/WinUI-Gallery/blob/d1441382f46265a6606c9afbd2096391ba93bd5d/WinUIGallery/MainWindow.xaml.cs#L389
                    QuerySubmitted="RequestsSearchBox_QuerySubmitted"
                -->
                <AutoSuggestBox x:Name="RequestsSearchBox"
                                Width="320"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                KeyboardAcceleratorPlacementMode="Hidden"
                                PlaceholderText="Search requests..."
                                QueryIcon="Find"
                                TextChanged="RequestsSearchBox_TextChanged">
                    <AutoSuggestBox.KeyboardAccelerators>
                        <KeyboardAccelerator
                            Key="F"
                            Invoked="CtrlF_Invoked"
                            Modifiers="Control" />
                    </AutoSuggestBox.KeyboardAccelerators>
                </AutoSuggestBox>
            </TitleBar.Content>
        </TitleBar>

        <NavigationView x:Name="RequestsNavigationView"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        IsPaneToggleButtonVisible="False"
                        SelectionChanged="RequestsNavigationView_SelectionChanged"
                        IsRightTapEnabled="True"
                        RightTapped="RequestsNavigationView_RightTapped"
                        Grid.Row="1">
            <NavigationView.Resources>
                <CommandBarFlyout Placement="Right" 
                                  AlwaysExpanded="True"
                                  x:Name="ContextCommandBarFlyout">
                    <AppBarButton Label="Delete" 
                                  Icon="Delete" 
                                  ToolTipService.ToolTip="Delete"
                                  Click="ContextDeleteButton_Click"/>
                </CommandBarFlyout>
            </NavigationView.Resources>

            <Frame x:Name="MainFrame" 
                   Grid.Row="1" />
        </NavigationView>
    </Grid>
</Window>
