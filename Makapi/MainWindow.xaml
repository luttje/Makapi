<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Makapi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Makapi"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Makapi">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid"
          Loaded="RootGrid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="TitleBar"
                  Title="Makapi"
                  IsBackButtonVisible="False"
                  PaneToggleRequested="TitleBar_PaneToggleRequested"
                  IsPaneToggleButtonVisible="True">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/Icon.ico" />
            </TitleBar.IconSource>

            <TitleBar.Content>
                <AutoSuggestBox x:Name="RequestsSearchBox"
                                Width="320"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                KeyboardAcceleratorPlacementMode="Hidden"
                                PlaceholderText="Search requests..."
                                QueryIcon="Find"
                                TextMemberPath="DisplayText"
                                TextChanged="RequestsSearchBox_TextChanged"
                                QuerySubmitted="RequestsSearchBox_QuerySubmitted">
                    <AutoSuggestBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayText}" 
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </AutoSuggestBox.ItemTemplate>
                    <AutoSuggestBox.KeyboardAccelerators>
                        <KeyboardAccelerator
                            Key="F"
                            Invoked="CtrlF_Invoked"
                            Modifiers="Control" />
                    </AutoSuggestBox.KeyboardAccelerators>
                </AutoSuggestBox>
            </TitleBar.Content>
        </TitleBar>

        <NavigationView x:Name="RequestsNavigationView"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        IsPaneToggleButtonVisible="False"
                        SelectionChanged="RequestsNavigationView_SelectionChanged"
                        IsRightTapEnabled="True"
                        RightTapped="RequestsNavigationView_RightTapped"
                        Grid.Row="1">
            <NavigationView.Resources>
                <CommandBarFlyout Placement="Right" 
                                  AlwaysExpanded="True"
                                  x:Name="ContextCommandBarFlyout">
                    <AppBarButton Label="Delete" 
                                  Icon="Delete" 
                                  ToolTipService.ToolTip="Delete"
                                  Click="ContextDeleteButton_Click"/>
                </CommandBarFlyout>
            </NavigationView.Resources>

            <Frame x:Name="MainFrame" 
                   Grid.Row="1" />
        </NavigationView>

        <!-- Loading overlay — visible during startup and refresh -->
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="2"
              Visibility="Visible"
              Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12"
                        MaxWidth="360"
                        MinWidth="240">

                <Image Source="/Assets/LoadingLogo.png"
                       MaxWidth="360"
                       MinWidth="240"
                       HorizontalAlignment="Center" />

                <ProgressBar x:Name="LoadingProgressBar"
                             IsIndeterminate="True"
                             HorizontalAlignment="Stretch"
                             Margin="0,4,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
